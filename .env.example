# Copy to .env and adjust. Everything has a working default for a first boot —
# change the secrets before putting this on the camp network.
#
# No host port: the app joins the shared external "web" docker network and is
# served by the Caddy reverse proxy at http://woodsvoice.10.0.12.189.nip.io
# (create the network once per host: docker network create web)

# Postgres
POSTGRES_DB=woodsvoice
POSTGRES_USER=woodsvoice
POSTGRES_PASSWORD=change-me-please

# Signs admin login tokens — make it long and random
JWT_SECRET=change-me-to-a-long-random-string

# First-boot admin account (created once, when the database is empty).
# It gets the Administrator role; create everyone else on the Team page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=WoodsVoice!demo

# Load a realistic demo dataset on first boot so the dashboard has life (true/false).
# Also seeds demo teammates (jake/maria/cindy, same password as the admin).
SEED_DEMO_DATA=true

# ---- AI triage ----
# Pick the engine in Settings → AI. Secrets live here, not in the database.
#   anthropic  → needs ANTHROPIC_API_KEY (model editable in Settings)
#   openai     → any OpenAI-compatible endpoint (Ollama on an LXC, LM Studio…);
#                base URL + model are set in Settings; OPENAI_API_KEY only if
#                your endpoint requires auth (Ollama doesn't)
#   keywords   → no AI at all; also the automatic fallback when a call fails
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=

# ---- Email notifications (SMTP) ----
# Without SMTP_HOST, notifications are logged on each submission's timeline
# instead of sent — the app works fine, you just don't get email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WoodsVoice <woodsvoice@muskokawoods.com>

# Org timezone for department hours & SLA clocks lives in Settings → General;
# this one just sets the container clock.
TZ=America/Toronto

# Testing only: freeze/jump the routing & SLA clock (ISO date). Leave empty.
FAKE_NOW=
